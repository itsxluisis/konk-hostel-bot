# ───── Vapi ─────
# Secret compartido que Vapi envía en cada webhook (header x-vapi-secret).
# Protege todos los endpoints /vapi/* y las rutas /admin/*.
VAPI_SECRET=cambia_esto_por_un_secreto_largo
# API key de la cuenta Vapi — usada por el panel admin para leer llamadas/asistente.
VAPI_API_KEY=

# ───── Cloudbeds (OAuth 2.0) ─────
CLOUDBEDS_CLIENT_ID=
CLOUDBEDS_CLIENT_SECRET=
CLOUDBEDS_REDIRECT_URI=https://tu-dominio.com/auth/cloudbeds/callback
CLOUDBEDS_PROPERTY_ID=
# Se obtienen tras autorizar en /auth/cloudbeds?token=VAPI_SECRET
CLOUDBEDS_ACCESS_TOKEN=
CLOUDBEDS_REFRESH_TOKEN=

# ───── Panel admin ─────
ADMIN_USER=admin
ADMIN_PASSWORD=

# ───── Telegram (resumen de llamadas) ─────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───── Servidor ─────
PORT=80
