{
  "type": "function",
  "function": {
    "name": "get_availability",
    "description": "Returns availability and indicative pricing for a date range. Read-only. Source: Cloudbeds.",
    "parameters": {
      "type": "object",
      "properties": {
        "checkin_date": {
          "type": "string",
          "format": "date",
          "description": "Check-in date, YYYY-MM-DD."
        },
        "checkout_date": {
          "type": "string",
          "format": "date",
          "description": "Check-out date, YYYY-MM-DD. Must be after checkin_date."
        },
        "guests": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Number of guests."
        },
        "preference": {
          "type": "string",
          "enum": ["private", "shared", "any"],
          "default": "any",
          "description": "Room preference stated by the guest: 'private' (whole room just for them), 'shared' (beds in a dorm), or 'any'."
        }
      },
      "required": ["checkin_date", "checkout_date", "guests"]
    }
  },
  "server": {
    "url": "{{WEBHOOK_BASE_URL}}/vapi/get-availability",
    "secret": "{{VAPI_SECRET}}",
    "timeoutSeconds": 8
  },
  "messages": [
    {
      "type": "request-start",
      "content": "Consulto disponibilidad, un segundo."
    }
  ]
}
